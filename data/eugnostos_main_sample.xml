            <head xml:lang="en">Eugnostos the Blessed — Nag Hammadi Codex III,3 (pp. 70–90)</head>
            <s xml:id="III-INCIPIT" n="1" source="marcion:INCIPIT" transJa="祝福されたエウグノストス、彼に属する者たちへ。これらのことを喜べ——" transEn="Eugnostos the blessed, to those who are his: rejoice in this —" transFr="Eugnostos le bienheureux, à ceux qui sont siens : réjouissez-vous de ceci —" ana="#th-dispositio #th-frame #th-sjc #th-witness" corresp="#wit-V" subtype="incipit">
              <w type="PREP" lemma="ⲉ">ⲉ</w><w type="NPROP" lemma="ⲩⲅⲛⲱⲥⲧⲟⲥ" xml:lang="grc">ⲩⲅⲛⲱⲥⲧⲟⲥ</w><w type="ART" lemma="ⲡ">ⲡ</w><w type="ADJ" lemma="ⲙⲁⲕⲁⲣⲓⲟⲥ" xml:lang="grc">ⲙⲁⲕⲁⲣⲓⲟⲥ</w><w type="PREP" lemma="ⲛ">ⲛ</w><w type="PRET" lemma="ⲛⲉ">ⲛⲉ</w>
              <w type="COP" lemma="ⲧⲉ">ⲧⲉ</w><w type="PREP" lemma="ⲛ">ⲛ</w><w type="ART" lemma="ⲟⲩ">ⲟⲩ</w><w type="PPER" lemma="ϥ">ϥ</w><w type="PRET" lemma="ⲛⲉ">ⲛⲉ</w><w type="CONJ" lemma="ϫⲉ">ϫⲉ</w>
              <w type="V" lemma="ⲣⲁϣⲉ">ⲣⲁϣⲉ</w><w type="PREP" lemma="ϩⲛ">ϩⲛ</w><w type="PRET" lemma="ⲛⲉ">ⲛⲉ</w><w type="V" lemma="ⲉⲓ">ⲉⲓ</w>
            </s>
            <s xml:id="III-7505191" n="2" source="marcion:7505191" transJa="世界の創設以来今に至るまで生まれたすべての人間が、神を求めて「神とは誰か、いかなる方か」と問いながらも見いだせずにいることを、あなたがたが知るために。世界の経綸より優れた知者たちでさえ満足しなかった。世界の統治について哲学者たちは三通りに語るが、彼らは互いに一致しない。ある者は、世界は自らによって治められると言う。" transEn="…that you may know that, from the foundation of the world until now, every human born has sought God, asking who and what he is, yet has not found him. Even the wise, beyond the governance of the world, were not satisfied. For the philosophers speak of the world&#x27;s governance in three ways and do not agree among themselves: some say the world is governed by itself;" transFr="… afin que vous sachiez que, depuis la fondation du monde jusqu&#x27;à maintenant, tout homme né a cherché Dieu, demandant qui et ce qu&#x27;il est, sans le trouver. Même les sages, au-delà du gouvernement du monde, ne furent pas satisfaits ; car les philosophes parlent du gouvernement du monde de trois manières et ne s&#x27;accordent pas entre eux : les uns disent que le monde se gouverne lui-même ;" ana="#th-apophatic #th-dispositio #th-frame #th-sjc">
              <w type="PREP" lemma="ⲉ">ⲉ</w><w type="V" lemma="ⲧⲣⲉⲧⲛ">ⲧⲣⲉⲧⲛ</w><w type="V" lemma="ⲉⲓⲙⲉ">ⲉⲓⲙⲉ</w><w type="CONJ" lemma="ϫⲉ">ϫⲉ</w><w type="N" lemma="ⲣⲱⲙⲉ">ⲣⲱⲙⲉ</w><w type="ADJ" lemma="ⲛⲓⲙ">ⲛⲓⲙ</w>
              <w type="REL" lemma="ⲛⲧ">ⲛⲧ</w><w type="PRET" lemma="ⲁ">ⲁ</w><w type="PPER" lemma="ⲩ">ⲩ</w><w type="V" lemma="ϫⲡⲟ">ϫⲡⲟ</w><w type="ART" lemma="ⲟⲩ">ⲟⲩ</w><w type="CONJ" lemma="ϫⲛ">ϫⲛ</w>
              <w type="PREP" lemma="ⲛ">ⲛ</w><w type="ART" lemma="ⲧ">ⲧ</w><w type="N" lemma="ⲕⲁⲧⲁⲃⲟⲗⲏ" xml:lang="grc">ⲕⲁⲧⲁⲃⲟⲗⲏ</w><w type="PREP" lemma="ⲙ">ⲙ</w><w type="ART" lemma="ⲡ">ⲡ</w><w type="N" lemma="ⲕⲟⲥⲙⲟⲥ" xml:lang="grc">ⲕⲟⲥⲙⲟⲥ</w>
              <w type="V" lemma="ϣⲁ">ϣⲁ</w><w type="ADV" lemma="ⲧⲉⲛⲟⲩ">ⲧⲉⲛⲟⲩ</w><w type="NUM" lemma="ⲥⲉ">ⲥⲉ</w><w type="VSTAT" lemma="ⲟ">ⲟ</w><w type="X" lemma="ⲛϣϩⲓϭ">ⲛϣϩⲓϭ</w><w type="PREP" lemma="ⲉ">ⲉ</w>
              <w type="PPER" lemma="ⲩ">ⲩ</w><w type="V" lemma="ϣⲓⲛⲉ">ϣⲓⲛⲉ</w><w type="PREP" lemma="ⲛ">ⲛ</w><w type="N" lemma="ⲥⲁ">ⲥⲁ</w><w type="ART" lemma="ⲡ">ⲡ</w><w type="V" lemma="ⲛⲟⲩ">ⲛⲟⲩ</w>
